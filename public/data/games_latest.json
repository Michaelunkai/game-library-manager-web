"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"description\" content=\"Game Library Manager - A Docker-based game library manager for downloading and organizing your game collection\">\n    <meta name=\"theme-color\" content=\"#6366f1\">\n    <title>Game Library Manager v4.0</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"styles.css?v=4.0\">\n    <link rel=\"icon\" href=\"data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎮</text></svg>\">\n</head>\n<body>\n    <div id=\"app\">\n        <!-- Header -->\n        <header class=\"header\">\n            <div class=\"header-left\">\n                <a href=\"https://github.com/Michaelunkai/game-library-manager-web\" target=\"_blank\" class=\"github-link\" title=\"View on GitHub\">\n                    <svg height=\"24\" width=\"24\" viewBox=\"0 0 16 16\" fill=\"currentColor\">\n                        <path d=\"M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z\"/>\n                    </svg>\n                </a>\n                <h1>🎮 Game Library Manager</h1>\n                <span class=\"version\">v4.0</span>\n            </div>\n            <div class=\"header-center\">\n                <div class=\"search-container\">\n                    <input type=\"text\" id=\"searchInput\" placeholder=\"Search games... (Ctrl+K)\" autocomplete=\"off\">\n                    <span class=\"search-icon\">🔍</span>\n                </div>\n            </div>\n            <div class=\"header-right\">\n                <div class=\"admin-login\" id=\"adminLoginBox\">\n                    <input type=\"password\" id=\"adminPassword\" placeholder=\"🔐 Admin\" autocomplete=\"off\">\n                </div>\n                <div class=\"admin-logged\" id=\"adminLoggedBox\" style=\"display: none;\">\n                    <span class=\"admin-badge\">👑 Admin</span>\n                    <button id=\"logoutBtn\" class=\"logout-btn\" title=\"Log out\">🚪</button>\n                </div>\n                <div class=\"stats\">\n                    <span id=\"gameCount\">0</span> games\n                    <span class=\"separator\">|</span>\n                    <span id=\"filteredCount\">0</span> shown\n                    <span class=\"separator\">|</span>\n                    <span id=\"selectedCount\">0</span> selected\n                </div>\n                <button id=\"sortBtn\" class=\"header-btn\" title=\"Sort games\">\n                    <span>Sort</span>\n                    <span id=\"sortIndicator\">↓ Name</span>\n                </button>\n                <button id=\"themeBtn\" class=\"header-btn\" title=\"Toggle theme\">🌙</button>\n                <button id=\"settingsBtn\" class=\"header-btn\" title=\"Settings\">⚙️</button>\n            </div>\n        </header>\n\n        <!-- Action Bar -->\n        <div class=\"action-bar\">\n            <div class=\"action-bar-left\">\n                <label class=\"path-input-label\">\n                    <span>📁 Mount Path:</span>\n                    <input type=\"text\" id=\"globalMountPath\" value=\"F:/Games\" placeholder=\"F:/Games\">\n                </label>\n                <button id=\"syncDockerBtn\" class=\"action-bar-btn sync-btn\" title=\"Sync with Docker Hub to find new tags\">🔄 Sync</button>\n            </div>\n            <div class=\"action-bar-center\">\n                <button id=\"showInstalledBtn\" class=\"action-bar-btn\">✅ Show Installed</button>\n                <button id=\"selectAllBtn\" class=\"action-bar-btn\">☑️ Select All</button>\n                <button id=\"deselectAllBtn\" class=\"action-bar-btn\">⬜ Deselect All</button>\n                <div class=\"run-dropdown-container\">\n                    <button id=\"runSelectedBtn\" class=\"action-bar-btn primary\" disabled>▶️ Run Selected (0)</button>\n                    <button id=\"runFormatBtn\" class=\"action-bar-btn primary format-toggle\" disabled title=\"Choose script format\">▼</button>\n                    <div id=\"runFormatMenu\" class=\"dropdown-menu format-menu\" style=\"display: none;\">\n                        <button class=\"format-option\" data-format=\"ps1\">📘 Download .PS1 (PowerShell)</button>\n                        <button class=\"format-option\" data-format=\"bat\">📗 Download .BAT (Batch)</button>\n                    </div>\n                </div>\n                <div class=\"move-to-container\">\n                    <button id=\"moveToBtn\" class=\"action-bar-btn\" disabled>📁 Move To</button>\n                    <div id=\"moveToMenu\" class=\"dropdown-menu move-to-menu\" style=\"display: none;\">\n                        <!-- Tabs will be populated by JavaScript -->\n                    </div>\n                </div>\n            </div>\n            <div class=\"action-bar-right\">\n                <div class=\"kill-dropdown-container\">\n                    <button id=\"killContainersBtn\" class=\"action-bar-btn danger\" title=\"Kill all Docker containers\">🛑 Kill All</button>\n                    <button id=\"killFormatBtn\" class=\"action-bar-btn danger format-toggle\" title=\"Choose script format\">▼</button>\n                    <div id=\"killFormatMenu\" class=\"dropdown-menu format-menu\" style=\"display: none;\">\n                        <button class=\"format-option\" data-format=\"ps1\">📘 Download .PS1 (PowerShell)</button>\n                        <button class=\"format-option\" data-format=\"bat\">📗 Download .BAT (Batch)</button>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- Main Content -->\n        <div class=\"main-container\">\n            <!-- Tabs Sidebar -->\n            <aside class=\"sidebar\">\n                <div class=\"tabs-header\">\n                    <h3>Categories</h3>\n                    <span id=\"tabCount\" class=\"tab-count\">29 tabs</span>\n                </div>\n                <nav id=\"tabsContainer\" class=\"tabs-nav\">\n                    <!-- Tabs will be populated by JavaScript -->\n                </nav>\n            </aside>\n\n            <!-- Games Grid -->\n            <main class=\"content\">\n                <div id=\"gamesGrid\" class=\"games-grid\">\n                    <!-- Games will be populated by JavaScript -->\n                </div>\n                <div id=\"loadingIndicator\" class=\"loading\">\n                    <div class=\"spinner\"></div>\n                    <p>Loading games...</p>\n                </div>\n                <div id=\"noResults\" class=\"no-results\" style=\"display: none;\">\n                    <p>No games found matching your search.</p>\n                </div>\n            </main>\n        </div>\n\n        <!-- Game Details Modal -->\n        <div id=\"gameModal\" class=\"modal\">\n            <div class=\"modal-content\">\n                <button class=\"modal-close\" id=\"modalClose\">&times;</button>\n                <div class=\"modal-body\">\n                    <div class=\"modal-image\">\n                        <img id=\"modalImage\" src=\"\" alt=\"Game cover\">\n                    </div>\n                    <div class=\"modal-info\">\n                        <h2 id=\"modalTitle\">Game Title</h2>\n                        <div class=\"modal-meta\">\n                            <span class=\"meta-item\">\n                                <span class=\"meta-label\">Category:</span>\n                                <span id=\"modalCategory\" class=\"meta-value category-badge\">Action</span>\n                            </span>\n                            <span class=\"meta-item\">\n                                <span class=\"meta-label\">HLTB Time:</span>\n                                <span id=\"modalTime\" class=\"meta-value\">~10 hours</span>\n                            </span>\n                            <span class=\"meta-item\">\n                                <span class=\"meta-label\">Docker Image Size:</span>\n                                <span id=\"modalSize\" class=\"meta-value\">0.0 GB</span>\n                            </span>\n                        </div>\n                        <div class=\"docker-section\">\n                            <h3>🐳 Docker Command</h3>\n                            <div class=\"command-box\">\n                                <code id=\"dockerCommand\">docker run...</code>\n                                <button id=\"copyCommand\" class=\"copy-btn\" title=\"Copy to clipboard\">📋</button>\n                            </div>\n                            <div class=\"action-buttons\">\n                                <div class=\"modal-run-dropdown\">\n                                    <button id=\"runDockerBtn\" class=\"action-btn primary\">\n                                        <span class=\"btn-icon\">▶️</span>\n                                        <span>Download .PS1</span>\n                                    </button>\n                                    <button id=\"runDockerBatBtn\" class=\"action-btn primary\">\n                                        <span class=\"btn-icon\">📦</span>\n                                        <span>Download .BAT</span>\n                                    </button>\n                                </div>\n                                <button id=\"copyScriptBtn\" class=\"action-btn secondary\">\n                                    <span class=\"btn-icon\">📄</span>\n                                    <span>Copy Script</span>\n                                </button>\n                            </div>\n                            <div class=\"terminal-info\">\n                                <p id=\"osInfo\">Detected OS: <span id=\"detectedOS\">Windows</span></p>\n                                <p class=\"terminal-hint\">Download .PS1 (PowerShell) or .BAT (Batch) script. Double-click to run!</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- Settings Modal -->\n        <div id=\"settingsModal\" class=\"modal\">\n            <div class=\"modal-content settings-modal\">\n                <button class=\"modal-close\" id=\"settingsClose\">&times;</button>\n                <h2>⚙️ Settings</h2>\n                <div class=\"settings-body\">\n                    <div class=\"setting-group\">\n                        <h3>Display</h3>\n                        <label class=\"setting-item\">\n                            <span>Grid Size</span>\n                            <select id=\"gridSize\">\n                                <option value=\"small\">Small</option>\n                                <option value=\"medium\" selected>Medium</option>\n                                <option value=\"large\">Large</option>\n                            </select>\n                        </label>\n                        <label class=\"setting-item\">\n                            <span>Show HLTB Times</span>\n                            <input type=\"checkbox\" id=\"showTimes\" checked>\n                        </label>\n                        <label class=\"setting-item\">\n                            <span>Show Categories</span>\n                            <input type=\"checkbox\" id=\"showCategories\" checked>\n                        </label>\n                    </div>\n                    <div class=\"setting-group\">\n                        <h3>Docker Settings</h3>\n                        <label class=\"setting-item\">\n                            <span>Docker Hub Username</span>\n                            <input type=\"text\" id=\"dockerUsername\" value=\"michadockermisha\" placeholder=\"Docker Hub username\">\n                        </label>\n                        <label class=\"setting-item\">\n                            <span>Repository Name</span>\n                            <input type=\"text\" id=\"repoName\" value=\"backup\" placeholder=\"Repository name\">\n                        </label>\n                        <label class=\"setting-item\">\n                            <span>Default Mount Path</span>\n                            <input type=\"text\" id=\"mountPath\" value=\"F:/Games\" placeholder=\"F:/Games\">\n                        </label>\n                    </div>\n                    <div class=\"setting-group\">\n                        <h3>Export/Import</h3>\n                        <div class=\"setting-actions\">\n                            <button id=\"exportData\" class=\"setting-btn\">📤 Export Data</button>\n                            <button id=\"importData\" class=\"setting-btn\">📥 Import Data</button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- Sort Menu -->\n        <div id=\"sortMenu\" class=\"dropdown-menu\" style=\"display: none;\">\n            <button data-sort=\"name\" data-order=\"asc\" class=\"sort-option active\">↓ Name (A-Z)</button>\n            <button data-sort=\"name\" data-order=\"desc\" class=\"sort-option\">↑ Name (Z-A)</button>\n            <button data-sort=\"time\" data-order=\"asc\" class=\"sort-option\">↓ Time (Low-High)</button>\n            <button data-sort=\"time\" data-order=\"desc\" class=\"sort-option\">↑ Time (High-Low)</button>\n            <button data-sort=\"size\" data-order=\"asc\" class=\"sort-option\">↓ Size (Small-Large)</button>\n            <button data-sort=\"size\" data-order=\"desc\" class=\"sort-option\">↑ Size (Large-Small)</button>\n            <button data-sort=\"date\" data-order=\"desc\" class=\"sort-option\">↓ Date (Newest-Oldest)</button>\n            <button data-sort=\"date\" data-order=\"asc\" class=\"sort-option\">↑ Date (Oldest-Newest)</button>\n            <button data-sort=\"category\" data-order=\"asc\" class=\"sort-option\">↓ Category</button>\n        </div>\n\n        <!-- Toast Notifications -->\n        <div id=\"toastContainer\" class=\"toast-container\"></div>\n\n        <!-- Scroll to Top Button -->\n        <button id=\"scrollTopBtn\" class=\"scroll-top-btn\" title=\"Scroll to top\" aria-label=\"Scroll to top\">\n            ↑\n        </button>\n\n        <!-- Mobile Sidebar Toggle -->\n        <button id=\"sidebarToggle\" class=\"sidebar-toggle\" title=\"Toggle categories\" aria-label=\"Toggle categories sidebar\">\n            ☰\n        </button>\n\n        <!-- Sidebar Overlay (for mobile) -->\n        <div id=\"sidebarOverlay\" class=\"sidebar-overlay\"></div>\n\n        <!-- Keyboard Shortcuts Hint -->\n        <div id=\"keyboardHints\" class=\"keyboard-hints\">\n            <span><kbd>Ctrl</kbd><kbd>K</kbd> Search</span>\n            <span><kbd>Esc</kbd> Close</span>\n            <span><kbd>↑</kbd><kbd>↓</kbd> Navigate</span>\n        </div>\n    </div>\n\n    <script src=\"app.js?v=4.0\"></script>\n</body>\n</html>\n"
